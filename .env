# --- REGISTRY ---
REGISTRY=ghcr.io
IMAGE_NAMESPACE=mooncake911/iot-service
TAG=latest

# --- VERSIONS ---
ELASTIC_VERSION=8.11.0
MONGO_VERSION=8.0
RABBIT_VERSION=4.0-management
GRAFANA_VERSION=10.2.0
PROMETHEUS_VERSION=v2.48.0

# --- PORTS ---
SIMULATOR_PORT=8081
CONTROLLER_PORT=8082
ANALYTICS_PORT=8083
ALERTS_PORT=8084
GATEWAY_PORT=8085
DASHBOARD_UI_PORT=8501

# --- DATABASE CONFIG ---
MONGO_USER=admin
MONGO_PASS=admin

# --- DATABASE CONFIG (CONTROLLER) ---
MONGO_CONTROLLER_PORT=27017
MONGO_CONTROLLER_DB=iot_db_controller
MONGO_CONTROLLER_URI="mongodb://${MONGO_USER}:${MONGO_PASS}@mongodb-controller:27017/${MONGO_CONTROLLER_DB}?authSource=admin"

# --- DATABASE CONFIG (ANALYTICS) ---
MONGO_ANALYTICS_PORT=27018
MONGO_ANALYTICS_DB=iot_analytics_db
MONGO_ANALYTICS_URI="mongodb://${MONGO_USER}:${MONGO_PASS}@mongodb-analytics:27017/${MONGO_ANALYTICS_DB}?authSource=admin"

# --- DATABASE CONFIG (ALERTS) ---
MONGO_ALERTS_PORT=27019
MONGO_ALERTS_DB=iot_alerts_db
MONGO_ALERTS_URI="mongodb://${MONGO_USER}:${MONGO_PASS}@mongodb-alerts:27017/${MONGO_ALERTS_DB}?authSource=admin"

# --- MESSAGE BROKER CONFIG (RABBITMQ) ---
RABBIT_INTERNAL_MQ_PORT=5672
RABBIT_INTERNAL_MGMT_PORT=15672
RABBIT_INTERNAL_STOMP_PORT=15674
RABBIT_INTERNAL_PROM_PORT=15692

RABBIT_MQ_PORT=5672
RABBIT_MGMT_PORT=15672
RABBIT_STOMP_PORT=15674
RABBIT_PROM_PORT=15692

RABBIT_USER=guest
RABBIT_PASS=guest
RABBIT_HOST=rabbitmq

# --- MONITORING & LOGGING CONFIG ---
ES_PORT=9200
LOGSTASH_PORT=5044
KIBANA_PORT=5601
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

ELASTIC_XPACK_SECURITY_ENABLED=false
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- SPRING SETTINGS ---
SPRING_INTERNAL_PORT=8080
SPRING_PROFILES=docker

# --- RESOURCE LIMITS ---
MONGO_CACHE_SIZE=0.5

ES_MEM_LIMIT=1g
LS_MEM_LIMIT=512m
KIBANA_MEM_LIMIT=1g

ES_JAVA_OPTS="-Xms512m -Xmx512m"
LS_JAVA_OPTS="-Xms256m -Xmx256m"
KIBANA_NODE_OPTIONS="--max-old-space-size=800 --no-openssl-legacy-provider"

# --- JAVA SETTINGS ---
JAVA_TOOL_OPTIONS="-Xshare:off -Xmx384m -XX:MaxDirectMemorySize=128m"
JDK_JAVA_OPTIONS="--enable-native-access=ALL-UNNAMED --add-opens java.base/java.nio=ALL-UNNAMED --add-opens java.base/jdk.internal.misc=ALL-UNNAMED --add-opens java.base/java.lang=ALL-UNNAMED"
