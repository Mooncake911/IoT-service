#!/bin/bash
# Daily backup script for IoT microservices MongoDB databases
set -euo pipefail

DEPLOY_DIR="{{ deploy_dir }}"
BACKUP_DIR="$DEPLOY_DIR/backups"
TIMESTAMP=$(date +"%Y%m%dT%H%M%S")
BUCKET="{{ backup_bucket_name }}"
ACCESS_KEY="{{ backup_storage_access_key }}"
SECRET_KEY="{{ backup_storage_secret_key }}"

# Read MongoDB credentials from .env
MONGO_USER=$(grep '^MONGO_USER=' "$DEPLOY_DIR/.env" 2>/dev/null | cut -d'=' -f2 || true)
MONGO_PASS=$(grep '^MONGO_PASS=' "$DEPLOY_DIR/.env" 2>/dev/null | cut -d'=' -f2 || true)

echo "=== Starting daily MongoDB backup at $(date) ==="

# Create backup folder if it does not exist
mkdir -p "$BACKUP_DIR"

# Build auth flags if credentials are available
if [ -n "${MONGO_USER:-}" ] && [ -n "${MONGO_PASS:-}" ]; then
  AUTH_FLAGS="--username $MONGO_USER --password $MONGO_PASS --authenticationDatabase admin"
else
  AUTH_FLAGS=""
  echo "Warning: MongoDB credentials not found in .env, dumping without auth"
fi

# Perform MongoDB dumps
if [ "$(docker ps -q -f name=mongodb-controller)" ]; then
  echo "Dumping mongodb-controller..."
  docker exec mongodb-controller mongodump --archive --gzip \
    $AUTH_FLAGS \
    > "$BACKUP_DIR/mongodb-controller_${TIMESTAMP}.archive"
fi
if [ "$(docker ps -q -f name=mongodb-analytics)" ]; then
  echo "Dumping mongodb-analytics..."
  docker exec mongodb-analytics mongodump --archive --gzip \
    $AUTH_FLAGS \
    > "$BACKUP_DIR/mongodb-analytics_${TIMESTAMP}.archive"
fi
if [ "$(docker ps -q -f name=mongodb-alerts)" ]; then
  echo "Dumping mongodb-alerts..."
  docker exec mongodb-alerts mongodump --archive --gzip \
    $AUTH_FLAGS \
    > "$BACKUP_DIR/mongodb-alerts_${TIMESTAMP}.archive"
fi

# Sync to Yandex Object Storage (S3) using MinIO mc
if [ -n "${BUCKET:-}" ] && [ -n "${ACCESS_KEY:-}" ] && [ -n "${SECRET_KEY:-}" ]; then
  echo "Uploading backups to Yandex Object Storage bucket: $BUCKET..."
  docker run --rm \
    -v "$BACKUP_DIR:/backups" \
    -e MC_HOST_s3="https://${ACCESS_KEY}:${SECRET_KEY}@storage.yandexcloud.net" \
    minio/mc:latest \
    cp --recursive /backups/ s3/{{ backup_bucket_name }}/backups/
else
  echo "Warning: S3 credentials are not configured, skipping upload."
fi

# Clean up local backups older than 7 days to save disk space
echo "Cleaning up local backups older than 7 days..."
find "$BACKUP_DIR" -type f -name "*.archive" -mtime +7 -delete

echo "=== Backup complete at $(date) ==="
